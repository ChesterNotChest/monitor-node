# Monitor Node — Server 连接配置
SERVER_BASE_URL=<server-ip>
WSS_SCHEME=ws
WSS_PORT=8081
RTMP_PORT=1935

# 调试模式
# DEBUG_WSS: WSS 调试模式——使用固定 Token 连接本地假 WSS 服务器
# RTMP_DEBUG: RTMP 调试模式——推流到本地 RTMP 服务器（127.0.0.1）
DEBUG_WSS=false
RTMP_DEBUG=false

# 应用
SECRET_KEY=change-me-to-a-random-string
DEBUG_INFO=false
